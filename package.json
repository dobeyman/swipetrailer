  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "jsdom": "^24.1.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jenre/trailerswipe"
  }
